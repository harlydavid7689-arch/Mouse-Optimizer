<Window x:Class="MouseOptimizer.Views.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MouseOptimizer" Height="360" Width="520"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" WindowStartupLocation="CenterScreen"
        Topmost="True">

    <Border CornerRadius="16" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0A0A0C" Offset="0"/>
                <GradientStop Color="#14080E" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <!-- Decorative background glow -->
            <Ellipse Width="300" Height="300" HorizontalAlignment="Center" VerticalAlignment="Center"
                     Margin="0,-60,0,0" Opacity="0.06">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#E01C2F" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <!-- Logo / icon area -->
                <Border Width="80" Height="80" CornerRadius="40"
                        HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E01C2F" Offset="0"/>
                            <GradientStop Color="#600A14" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#E01C2F" Opacity="0.6"/>
                    </Border.Effect>
                    <TextBlock Text="🖱" FontSize="36"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Title -->
                <TextBlock Text="MOUSE OPTIMIZER" FontFamily="Segoe UI" FontSize="22"
                           FontWeight="Black" Foreground="White" TextAlignment="Center"
                           CharacterSpacing="300">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#E01C2F" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="ESPORTS PERFORMANCE UTILITY" FontFamily="Segoe UI" FontSize="9"
                           FontWeight="SemiBold" Foreground="#6A3040" TextAlignment="Center"
                           CharacterSpacing="400" Margin="0,4,0,32"/>

                <!-- Loading bar -->
                <Grid Width="260" Margin="0,0,0,16">
                    <Border Background="#1A1A22" CornerRadius="3" Height="4"/>
                    <Border x:Name="LoadBar" Background="{StaticResource BrAccentRed}"
                            CornerRadius="3" Height="4" HorizontalAlignment="Left" Width="0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#E01C2F" Opacity="0.8"/>
                        </Border.Effect>
                    </Border>
                </Grid>

                <TextBlock x:Name="LoadingLabel" Text="Initializing..." FontFamily="Segoe UI"
                           FontSize="10" Foreground="#4A4A5A" TextAlignment="Center"/>
            </StackPanel>

            <!-- Version tag -->
            <TextBlock Text="v1.0.0" FontFamily="Segoe UI" FontSize="9"
                       Foreground="#2A2A3A" HorizontalAlignment="Right"
                       VerticalAlignment="Bottom" Margin="0,0,16,14"/>
        </Grid>
    </Border>
</Window>
